{
  "version": "1.0.0",
  "rules": [
    {
      "pattern": "infrastructure/core/**/*",
      "owner": "hub",
      "description": "Base SST/CDK constructs and agentic architecture"
    },
    {
      "pattern": "packages/agents/core/**/*",
      "owner": "hub",
      "description": "Canonical agent logic and reflection patterns"
    },
    {
      "pattern": "sst.config.ts",
      "owner": "hub",
      "strategy": "merge",
      "description": "Main infrastructure definition (merged with client links)"
    },
    {
      "pattern": "package.json",
      "owner": "hub",
      "strategy": "merge",
      "description": "Dependency management"
    },
    {
      "pattern": "config/**/*",
      "owner": "spoke",
      "description": "Client-specific business parameters"
    },
    {
      "pattern": "app/business-logic/**/*",
      "owner": "spoke",
      "description": "The client's unique value proposition"
    }
  ],
  "harvester": {
    "allow_patterns": [
      "abstract-patterns",
      "optimization-logic",
      "security-hardening"
    ],
    "deny_patterns": [
      "secrets",
      "api-keys",
      "pii",
      "branding",
      "custom-prompts"
    ]
  }
}
