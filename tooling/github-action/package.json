{
  "name": "aiready-action",
  "version": "1.1.0",
  "description": "AIReady GitHub Action - Block PRs that break your AI context budget",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --out-dir dist --no-splitting --minify",
    "prepare": "pnpm build",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check . --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "github-action",
    "ai",
    "code-quality",
    "linting",
    "readiness"
  ],
  "author": "AIReady",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/caopengau/aiready-action.git"
  }
}
